# Backend-local runtime defaults for direct local development.
# This file is intended for local-only configuration of the API, worker, and
# ingest task runtimes. Keep real secrets out of source control.

# Runtime environment label used by local entrypoints and env-driven config.
APP_ENV=dev

# Default AWS region for SDK clients and AWS-style config resolution in local runs.
AWS_DEFAULT_REGION=us-east-1

# Primary platform relational store toggle.
# Enables PostgreSQL-backed customer-account, billing, and platform persistence.
PLATFORM_POSTGRES_ENABLED=true

# SQLAlchemy URL for the primary platform PostgreSQL database.
PLATFORM_POSTGRES_URL=postgresql+psycopg://postgres:postgres@localhost:5432/verification_platform

# Nonprofit read-model persistence backend for local runs.
PLATFORM_NONPROFIT_STORE_BACKEND=postgres

# Nonprofit query backend used by the API runtime.
PLATFORM_NONPROFIT_QUERY_BACKEND=postgres

# API authentication enforcement toggle for local development.
API_AUTH_ENABLED=false

# OAuth machine-to-machine token issuance/validation toggle.
OAUTH_M2M_ENABLED=false

# Local signing secret for portal bearer/session tokens.
PORTAL_AUTH_TOKEN_SECRET=replace-me

# Support-ticket delivery toggle.
# Leave false unless you want the local portal support flow to send mail.
SUPPORT_TICKET_EMAIL_ENABLED=false

# Outbound support-ticket delivery provider.
SUPPORT_TICKET_EMAIL_PROVIDER=gmail_smtp

# Destination email address for submitted support tickets.
SUPPORT_TICKET_EMAIL_TO=your-email@example.com

# From-address used for support-ticket email delivery.
SUPPORT_TICKET_EMAIL_FROM=your-email@example.com

# Subject prefix prepended to all support-ticket emails.
SUPPORT_TICKET_EMAIL_SUBJECT_PREFIX=[Verification Support]

# SMTP host for support-ticket email delivery.
SUPPORT_TICKET_SMTP_HOST=smtp.gmail.com

# SMTP port for support-ticket email delivery.
SUPPORT_TICKET_SMTP_PORT=587

# SMTP username for support-ticket email delivery.
SUPPORT_TICKET_SMTP_USERNAME=your-email@example.com

# SMTP app password or provider-specific credential for support email delivery.
SUPPORT_TICKET_SMTP_APP_PASSWORD=replace-me

# STARTTLS toggle for the support-ticket SMTP connection.
SUPPORT_TICKET_SMTP_STARTTLS=true

# SMTP socket timeout in seconds for support-ticket delivery attempts.
SUPPORT_TICKET_SMTP_TIMEOUT_SECONDS=15

# Local scratch/workspace directory used by Form 990 ingest processing.
FORM990_WORKSPACE_DIR=./.workspace/form990

# Maximum local workspace size available to Form 990 processing, in bytes.
FORM990_WORKSPACE_MAX_BYTES=34359738368

# Comma-separated CORS allowlist for local frontend and API origins.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:8000,http://127.0.0.1:8000

# Dedicated nonprofit relational store toggle.
# Keeps normalized nonprofit data isolated from the main platform database.
PLATFORM_NONPROFIT_POSTGRES_ENABLED=true

# SQLAlchemy URL for the nonprofit domain PostgreSQL database.
PLATFORM_NONPROFIT_POSTGRES_URL=postgresql+psycopg://postgres:postgres@localhost:5432/verification_nonprofit

# SQLAlchemy URL for the nonprofit query PostgreSQL database.
PLATFORM_NONPROFIT_QUERY_POSTGRES_URL=postgresql+psycopg://postgres:postgres@localhost:5432/verification_nonprofit_query

# Host/interface bound by the local API server.
BACKEND_API_HOST=0.0.0.0

# TCP port exposed by the local API server.
BACKEND_API_PORT=8001
