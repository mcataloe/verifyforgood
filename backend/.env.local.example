# Backend-local runtime defaults for direct local development.
# Copy to backend/.env.local and adjust the PostgreSQL URL as needed.

APP_ENV=dev
AWS_DEFAULT_REGION=us-east-1
PLATFORM_POSTGRES_ENABLED=true
PLATFORM_POSTGRES_URL=postgresql+psycopg://postgres:postgres@localhost:5432/verification_platform
# Optional dedicated nonprofit data-plane database. Leave unset to reuse PLATFORM_POSTGRES_URL.
# PLATFORM_NONPROFIT_POSTGRES_ENABLED=true
# PLATFORM_NONPROFIT_POSTGRES_URL=postgresql+psycopg://postgres:postgres@localhost:5432/verification_nonprofit
PLATFORM_NONPROFIT_STORE_BACKEND=postgres
PLATFORM_NONPROFIT_QUERY_BACKEND=postgres
API_AUTH_ENABLED=false
OAUTH_M2M_ENABLED=false
PORTAL_AUTH_TOKEN_SECRET=dev-portal-auth-secret
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:8000,http://127.0.0.1:8000
FORM990_WORKSPACE_DIR=./.workspace/form990
FORM990_WORKSPACE_MAX_BYTES=34359738368
