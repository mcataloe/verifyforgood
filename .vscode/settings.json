{
  "yaml.schemas": {
    "https://www.artillery.io/schema.json": []
  },
  "python.defaultInterpreterPath": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
  "python.analysis.extraPaths": [
    "${workspaceFolder}\\infrastructure",
    "${workspaceFolder}\\private-platform\\src",
    "${workspaceFolder}\\public-core\\src",
    "${workspaceFolder}\\backend\\shared\\src",
    "${workspaceFolder}\\backend\\ingest-task\\src",
    "${workspaceFolder}\\backend\\api\\src",
    "${workspaceFolder}\\backend\\worker\\src"
  ],
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always"
  },
  "[prisma]": {
    "editor.defaultFormatter": "Prisma.prisma"
  },
  "[terraform]": {
    "editor.defaultFormatter": "hashicorp.terraform",
    "editor.formatOnSave": true
  },
  "python-envs.pythonProjects": [
    {
      "path": ".",
      "envManager": "ms-python.python:venv",
      "packageManager": "ms-python.python:pip"
    }
  ]
}
