{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Frontend Portal",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/frontend/portal/src"
    },
    {
      "name": "Backend API",
      "type": "python",
      "request": "launch",
      "module": "charity_status_backend.api.entrypoint",
      "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/backend/.env.local",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Form990 Monthly Pipeline",
      "type": "python",
      "request": "launch",
      "module": "charity_status_backend.ingest_task.cli.monthly_ingest_task",
      "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/backend/.env.local",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "APP_ENV": "dev",
        "FORM990_WORKSPACE_DIR": "${workspaceFolder}/backend/ingest-task/.workspace/form990",
        "MONTHLY_INGEST_WORKFLOW_NAME": "monthly-ingest-dev",
        "MONTHLY_INGEST_WORKFLOW_VERSION": "2026-03",
        "MONTHLY_INGEST_JOB_ID": "local-monthly-debug-2024-teos-xml-01a",
        "MONTHLY_INGEST_CORRELATION_ID": "local-monthly-debug-2024-teos-xml-01a",
        "MONTHLY_INGEST_SOURCE_KEY": "form990/raw-sources/2024/zip_archive/2024_teos_xml_01a/local-debug/2024_TEOS_XML_01A.zip",
        "MONTHLY_INGEST_DESTINATION_PREFIX": "form990/monthly-debug",
        "MONTHLY_INGEST_INPUT_JSON": "{\"correlation_id\":\"local-monthly-debug-2024-teos-xml-01a\",\"destination_prefix\":\"form990/monthly-debug\",\"job_id\":\"local-monthly-debug-2024-teos-xml-01a\",\"schedule_context\":{\"source_url\":\"https://apps.irs.gov/pub/epostcard/990/xml/2024/2024_TEOS_XML_01A.zip\"},\"source_key\":\"form990/raw-sources/2024/zip_archive/2024_teos_xml_01a/local-debug/2024_TEOS_XML_01A.zip\",\"workflow_version\":\"2026-03\"}"
      }
    },
    {
      "name": "Form990 Local Run",
      "type": "python",
      "request": "launch",
      "module": "ingest_task.cli",
      "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/backend/.env.local",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "FORM990_WORKSPACE_DIR": "${workspaceFolder}/backend/ingest-task/.workspace/form990"
      },
      "args": [
        "run",
        "--archive-url",
        "https://apps.irs.gov/pub/epostcard/990/xml/2024/2024_TEOS_XML_01A.zip",
        "--strict"
      ]
    },
    {
      "name": "EO BMF Local Run",
      "type": "python",
      "request": "launch",
      "module": "charity_status_backend.ingest_task.cli",
      "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/backend/.env.local",
      "console": "integratedTerminal",
      "justMyCode": false,
      "args": ["run-eo-bmf"],
      "env": {
        "EOBMF_WORKSPACE_DIR": "${workspaceFolder}/backend/ingest-task/.workspace/eo_bmf"
      }
    },
    {
      "name": "Form990 ECS Parity",
      "type": "python",
      "request": "launch",
      "module": "charity_status_backend.ingest_task.cli",
      "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/backend/.env.local",
      "console": "integratedTerminal",
      "justMyCode": false,
      "args": ["ecs-run"],
      "env": {
        "WORKSPACE_PATH": "${workspaceFolder}/backend/ingest-task/.workspace/form990"
      }
    },

    {
      "name": "EO BMF ECS Parity",
      "type": "python",
      "request": "launch",
      "module": "charity_status_backend.ingest_task.cli",
      "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/backend/.env.local",
      "console": "integratedTerminal",
      "justMyCode": false,
      "args": ["ecs-run-eo-bmf"],
      "env": {
        "WORKSPACE_PATH": "${workspaceFolder}/backend/ingest-task/.workspace/eo_bmf"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Launch Program",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}\\application\\src\\pages\\api\\v1\\message\\index.ts",
      "outFiles": ["${workspaceFolder}/**/*.js"]
    }
  ]
}
