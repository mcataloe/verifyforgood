{
  "name": "charity-status-frontend-workspace",
  "private": true,
  "workspaces": [
    "marketing",
    "portal",
    "shared/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @charity-status/marketing && npm run build --workspace @charity-status/portal",
    "dev:marketing": "npm run dev --workspace @charity-status/marketing",
    "dev:portal": "npm run dev --workspace @charity-status/portal",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.0.0"
  }
}
