{
  "name": "charity-status-frontend-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "docs",
    "marketing",
    "portal",
    "shared/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @charity-status/marketing && npm run build --workspace @charity-status/portal && npm run build --workspace @charity-status/docs",
    "dev:docs": "npm run dev --workspace @charity-status/docs",
    "dev:marketing": "npm run dev --workspace @charity-status/marketing",
    "dev:portal": "npm run dev --workspace @charity-status/portal",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "npm run typecheck:tooling && npm run typecheck:packages",
    "typecheck:packages": "npm run typecheck --workspaces --if-present",
    "typecheck:tooling": "tsc --project tsconfig.tooling.json --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
