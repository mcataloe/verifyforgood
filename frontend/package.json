{
  "name": "charity-status-frontend-workspace",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @charity-status/marketing build && pnpm --filter @charity-status/portal build && pnpm --filter @charity-status/docs build",
    "dev:docs": "pnpm --filter @charity-status/docs dev",
    "dev:marketing": "pnpm --filter @charity-status/marketing dev",
    "dev:portal": "pnpm --filter @charity-status/portal dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm run typecheck:tooling && pnpm run typecheck:packages",
    "typecheck:packages": "pnpm -r --if-present typecheck",
    "typecheck:tooling": "tsc --project tsconfig.tooling.json --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
