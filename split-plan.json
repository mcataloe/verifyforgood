{
  "operational_layers": {
    "frontend": {
      "root": "frontend/",
      "role": "browser/runtime UI layer",
      "notes": [
        "Owns the pnpm workspace and frontend-only shared packages.",
        "Must not import Python runtime code from backend, private-platform, or infrastructure."
      ]
    },
    "backend": {
      "root": "backend/",
      "role": "executable runtime host layer",
      "subdirectories": [
        "backend/api/",
        "backend/worker/",
        "backend/ingest-task/",
        "backend/shared/"
      ],
      "notes": [
        "Owns runtime hosts, transport/bootstrap assembly, and runtime-shared concerns.",
        "May depend on public-core and private-platform, but does not replace them."
      ]
    },
    "infrastructure": {
      "root": "infrastructure/",
      "role": "deployment/config/wiring layer",
      "notes": [
        "May package and deploy backend entrypoints.",
        "Should converge on Terraform, env wiring, scripts, and temporary compatibility shims only."
      ]
    }
  },
  "public_repo": {
    "package_root": "public-core/src/verification",
    "include": [
      "public-core/"
    ],
    "candidate_modules": [
      "infrastructure/verification/decision/",
      "infrastructure/verification/evidence/",
      "infrastructure/verification/normalization/",
      "infrastructure/verification/policy/",
      "infrastructure/verification/scoring/",
      "infrastructure/verification/sources/",
      "infrastructure/verification/state_registry/",
      "infrastructure/verification/query/verification.py",
      "infrastructure/verification/query/nonprofit_lookup.py",
      "infrastructure/verification/query/source_views.py",
      "infrastructure/verification/enrichments/service.py",
      "infrastructure/verification/serving/materializer.py",
      "infrastructure/verification/serving/refresh.py",
      "infrastructure/verification/serving/change_detection.py",
      "infrastructure/verification/serving/models.py",
      "infrastructure/verification/form990/"
    ],
    "mixed_before_extract": [
      "infrastructure/verification/core/",
      "infrastructure/verification/query/",
      "infrastructure/verification/enrichments/",
      "infrastructure/verification/serving/",
      "infrastructure/verification/form990/"
    ],
    "notes": [
      "Public-core is deterministic nonprofit/domain logic only.",
      "All billing stays private-platform.",
      "AWS, Stripe, env parsing, and transport response shaping stay out of public-core."
    ]
  },
  "private_repo": {
    "package_root": "private-platform/src/verification_platform",
    "include": [
      "private-platform/"
    ],
    "service_areas": {
      "identity_access": [
        "infrastructure/verification/auth/",
        "infrastructure/verification/platform/auth.py"
      ],
      "customer_accounts": [
        "infrastructure/verification/control_plane/",
        "infrastructure/verification/enrichments/organization_store.py",
        "infrastructure/verification/enrichments/organization_settings_service.py",
        "infrastructure/verification/enrichments/organization_settings_stores.py"
      ],
      "billing_usage": [
        "infrastructure/verification/billing/",
        "infrastructure/verification/auth/service.py"
      ],
      "admin_operations": [
        "infrastructure/verification/ops/"
      ],
      "runtime": [
        "infrastructure/verification/platform/",
        "infrastructure/lambda_query.py",
        "infrastructure/lambda_refresh.py",
        "infrastructure/eo_bmf_ingest_worker.py",
        "infrastructure/monthly_ingest_worker.py",
        "infrastructure/nonprofit_ingest_persistence.py"
      ],
      "notifications": []
    },
    "candidate_modules": [
      "infrastructure/verification/auth/",
      "infrastructure/verification/billing/",
      "infrastructure/verification/control_plane/",
      "infrastructure/verification/ingest/",
      "infrastructure/verification/ops/",
      "infrastructure/verification/platform/",
      "infrastructure/verification/query/athena.py",
      "infrastructure/verification/serving/dynamodb_store.py",
      "infrastructure/verification/enrichments/organization_store.py",
      "infrastructure/lambda_query.py",
      "infrastructure/lambda_refresh.py",
      "infrastructure/eo_bmf_ingest_worker.py",
      "infrastructure/monthly_ingest_worker.py",
      "infrastructure/nonprofit_ingest_persistence.py"
    ],
    "notes": [
      "Private-platform owns all platform billing.",
      "Private-platform owns runtime orchestration, control-plane, auth, ops, and proprietary adapters."
    ]
  },
  "infra_repo": {
    "include": [
      "infra-deployment/"
    ],
    "deployment_assets": [
      "infrastructure/*.tf",
      "infrastructure/backend-*.hcl",
      "infrastructure/*.tfvars",
      "infrastructure/*.tfvars.example"
    ],
    "notes": [
      "Infrastructure should converge on deploy/config/wiring only.",
      "Business logic should migrate out before extraction."
    ]
  },
  "entrypoints": [
    "infrastructure/verification/api/routes.py",
    "infrastructure/verification/api/responses.py",
    "infrastructure/lambda_query.py",
    "infrastructure/lambda_refresh.py",
    "infrastructure/eo_bmf_ingest_worker.py",
    "infrastructure/monthly_ingest_worker.py",
    "infrastructure/nonprofit_ingest_persistence.py"
  ],
  "shared_contracts": [
    "infrastructure/verification/api/routes.py",
    "infrastructure/verification/api/responses.py",
    "infrastructure/verification/core/interfaces.py",
    "private-platform/src/verification_platform/runtime/backend_contracts.py",
    "private-platform/src/verification_platform/runtime/entrypoints.py"
  ],
  "backend_runtime_targets": {
    "public_api": {
      "current_handler": "infrastructure.lambda_query.handler",
      "target_directory": "backend/api/",
      "notes": [
        "Primary API server runtime host.",
        "Owns ASGI/bootstrap, request composition, and health/readiness ownership."
      ]
    },
    "profile_refresh_job": {
      "current_handler": "infrastructure.lambda_refresh.handler",
      "target_directory": "backend/worker/",
      "notes": [
        "Non-HTTP refresh runtime host."
      ]
    },
    "eo_ingest_job": {
      "current_handler": "infrastructure.eo_bmf_ingest_worker.handler",
      "target_directory": "backend/ingest-task/",
      "notes": [
        "EO/BMF ingest runtime host."
      ]
    },
    "monthly_ingest_job": {
      "current_handler": "infrastructure.monthly_ingest_worker.main",
      "target_directory": "backend/ingest-task/",
      "notes": [
        "Canonical Form 990 monthly ingest runtime host.",
        "Uses the workspace-plus-PostgreSQL runtime instead of the retired Lambda/S3 ingest flow."
      ]
    },
    "runtime_shared_contracts": {
      "current_paths": [
        "infrastructure/verification/api/routes.py",
        "infrastructure/verification/api/responses.py",
        "infrastructure/verification/core/interfaces.py",
        "infrastructure/verification/platform/"
      ],
      "target_directory": "backend/shared/",
      "notes": [
        "Shared runtime-facing transport, bootstrap, and compatibility helpers.",
        "private-platform runtime compatibility exports remain during the transition."
      ]
    }
  },
  "test_layers": {
    "public_core_unit": [
      "public-core/tests/"
    ],
    "private_platform_unit": [
      "private-platform/tests/"
    ],
    "integration_and_compatibility": [
      "tests/"
    ]
  },
  "highest_risk_refactors": [
    "infrastructure/lambda_query.py",
    "infrastructure/verification/core/models.py",
    "infrastructure/verification/billing/",
    "infrastructure/verification/query/athena.py",
    "infrastructure/verification/enrichments/organization_store.py",
    "infrastructure/verification/form990/",
    "infrastructure/verification/serving/"
  ],
  "dependency_rules": [
    "frontend must not import Python runtime code from backend, private-platform, or infrastructure",
    "backend may depend on public-core and private-platform",
    "verification_platform may depend on verification",
    "verification must not depend on verification_platform",
    "private-platform must not depend on backend or infrastructure",
    "infrastructure may package and deploy entrypoints but must not contain business logic",
    "all billing stays private-platform",
    "shared backend transport contracts stay private-platform/runtime until explicitly extracted elsewhere"
  ],
  "migration_sequence": [
    "document backend operational layers and tighten split scaffolding",
    "introduce backend/shared compatibility wrappers and runtime bootstrap seams",
    "extract runtime hosts from infrastructure into backend",
    "remove core-to-billing dependency and split mixed adapters from domain logic",
    "extract low-risk deterministic public-core packages",
    "extract private-platform orchestration, billing, auth, control-plane, and adapters",
    "reduce infrastructure to deployment/config/wiring only"
  ]
}

