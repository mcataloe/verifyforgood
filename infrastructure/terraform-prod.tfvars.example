environment = "prod"
form990_schedule_expression = ""
refresh_schedule_expression = ""
platform_postgres_enabled   = false
platform_postgres_backup_retention_days = 7
platform_postgres_deletion_protection_enabled = true
platform_postgres_skip_final_snapshot = false
api_ecs_vpc_id              = "vpc-xxxxxxxx"
api_ecs_public_subnet_ids   = ["subnet-public-xxxxxxxx", "subnet-public-yyyyyyyy"]
api_ecs_private_subnet_ids  = ["subnet-private-xxxxxxxx", "subnet-private-yyyyyyyy"]
api_alb_certificate_arn     = ""
api_ecs_image_uri           = ""
api_ecs_secret_arns         = {}
worker_ecs_vpc_id           = "vpc-xxxxxxxx"
worker_ecs_private_subnet_ids = ["subnet-private-xxxxxxxx", "subnet-private-yyyyyyyy"]
worker_ecs_image_uri        = ""
worker_ecs_secret_arns      = {}
enable_custom_domain        = false
cors_allowed_origins = [
  "https://charitystatusapi.com",
]
