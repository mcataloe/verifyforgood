environment = "dev"
form990_schedule_expression = "cron(30 4 * * ? *)"
form990_execution_mode      = "orchestrated"
form990_incremental_year_window = 1
refresh_schedule_expression = "cron(0 6 * * ? *)"
platform_postgres_enabled   = false
platform_postgres_vpc_id    = "vpc-xxxxxxxx"
platform_postgres_private_subnet_ids = ["subnet-xxxxxxxx", "subnet-yyyyyyyy"]
api_ecs_vpc_id              = "vpc-xxxxxxxx"
api_ecs_public_subnet_ids   = ["subnet-public-xxxxxxxx", "subnet-public-yyyyyyyy"]
api_ecs_private_subnet_ids  = ["subnet-xxxxxxxx", "subnet-yyyyyyyy"]
api_alb_certificate_arn     = ""
api_ecs_image_uri           = ""
api_ecs_secret_arns         = {}
worker_ecs_vpc_id           = "vpc-xxxxxxxx"
worker_ecs_private_subnet_ids = ["subnet-xxxxxxxx", "subnet-yyyyyyyy"]
worker_ecs_image_uri        = ""
worker_ecs_secret_arns      = {}
enable_custom_domain        = true
cors_allowed_origins = [
  "http://localhost:5173",
  "http://127.0.0.1:5173",
  "http://localhost:5174",
  "http://127.0.0.1:5174",
  "https://dev.charitystatusapi.com",
]
